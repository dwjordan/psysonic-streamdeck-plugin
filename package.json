{
  "name": "com.dwjordan.psysonic",
  "version": "0.1.0",
  "description": "Psysonic control for Elgato Stream Deck with live album art.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.dwjordan.psysonic\"",
    "icons": "node scripts/generate-icons.mjs"
  },
  "author": "Dave Jordan",
  "license": "MIT",
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "20.x",
    "rollup": "^4.24.0",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0"
  }
}
